# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Application
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development

# ThingSpeak
THINGSPEAK_MQTT_USER=your-thingspeak-mqtt-username
THINGSPEAK_MQTT_API_KEY=your-thingspeak-mqtt-api-key
THINGSPEAK_MQTT_CLIENT_ID=your-thingspeak-mqtt-client-id-optional
THINGSPEAK_REST_API_KEY=your-thingspeak-channel-read-api-key-optional
